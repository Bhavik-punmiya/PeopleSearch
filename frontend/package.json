{
  "name": "peoplesearch",
  "productName": "PeopleSearch",
  "version": "1.0.0",
  "description": "HR Data Management Application",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "dist": "electron-forge package && electron-builder",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "build": {
    "appId": "com.peoplesearch.app",
    "productName": "PeopleSearch",
    "directories": {
      "output": "dist_builder"
    },
    "win": {
      "target": "nsis",
      "icon": "public/hr-logo/android-chrome-512x512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PeopleSearch"
    },
    "extraResources": [
      {
        "from": "../backend/dist/backend.exe",
        "to": "backend.exe"
      },
      {
        "from": "people.db",
        "to": "people.db"
      }
    ],
    "files": [
      ".vite/build/**/*",
      "package.json"
    ]
  },
  "keywords": [],
  "author": {
    "name": "Bhavik-punmiya",
    "email": "Bhavikpunmiya@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "electron": "41.3.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "lucide-react": "^1.12.0",
    "postcss": "^8.5.12",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~4.5.4",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
